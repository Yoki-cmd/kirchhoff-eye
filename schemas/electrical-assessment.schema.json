{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kirchhoff-electrical-assessment-1.0.schema.json",
  "title": "kirchhoff-electrical-assessment/1.0",
  "type": "object",
  "required": ["version", "candidate_ir_sha256", "audit_sha256", "verdict", "summary", "claims"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": "kirchhoff-electrical-assessment/1.0"},
    "candidate_ir_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "audit_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "verdict": {"enum": ["pass", "warn", "needs_context", "requires_repair"]},
    "summary": {"type": "string", "minLength": 1},
    "claims": {
      "type": "array",
      "items": {"$ref": "#/definitions/claim"}
    }
  },
  "definitions": {
    "claim": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "basis",
        "ir_paths",
        "description",
        "assumptions",
        "confidence",
        "disposition",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "severity": {"enum": ["blocker", "warning", "info"]},
        "basis": {
          "enum": [
            "first_principles",
            "audit_finding",
            "recognized_motif",
            "source_evidence",
            "engineering_heuristic"
          ]
        },
        "audit_finding_id": {"type": "string", "pattern": "^EA[0-9]{3}-[1-9][0-9]*$"},
        "ir_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^/"},
          "uniqueItems": true
        },
        "description": {"type": "string", "minLength": 1},
        "assumptions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "disposition": {
          "enum": [
            "accept_as_plausible",
            "confirm_source_intended",
            "reinspect_source",
            "repair_ir",
            "needs_context"
          ]
        },
        "linked_difference_id": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"disposition": {"const": "repair_ir"}}},
          "then": {"required": ["linked_difference_id"]}
        }
      ]
    }
  }
}
