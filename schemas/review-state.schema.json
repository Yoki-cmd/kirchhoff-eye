{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kirchhoff-review-state-1.0.schema.json",
  "title": "kirchhoff-review-state/1.0",
  "type": "object",
  "required": [
    "report_version", "status", "task", "validation_status", "layout_status",
    "current_round", "max_rounds", "review_required", "ready_for_approval", "reason_codes",
    "rounds", "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "report_version": {"const": "kirchhoff-review/1.0"},
    "status": {"enum": ["valid", "needs_review", "needs_human", "approved"]},
    "task": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {"enum": ["redraw-image", "draw-from-description", "draw-from-netlist", "edit-ir", "render"]},
        "input_artifact": {"type": "string", "minLength": 1}
      }
    },
    "validation_status": {"enum": ["ok", "warn"]},
    "layout_status": {"enum": ["ok", "warn"]},
    "current_round": {"type": "integer", "minimum": 1},
    "max_rounds": {"type": "integer", "minimum": 1},
    "review_required": {"type": "boolean"},
    "ready_for_approval": {"type": "boolean"},
    "reason_codes": {"type": "array", "items": {"type": "string"}},
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["round", "reviewed", "regions", "differences", "applied_patches", "artifacts", "ir_sha256"],
        "additionalProperties": false,
        "properties": {
          "round": {"type": "integer", "minimum": 1},
          "reviewed": {"type": "boolean"},
          "regions": {"type": "array"},
          "differences": {"type": "array"},
          "applied_patches": {"type": "array"},
          "artifacts": {"type": "object"},
          "ir_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "comparison_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "reviewed_ir_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "reviewed_source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "reviewed_comparison_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "change_evidence": {"type": "object"}
        }
      }
    },
    "artifacts": {"type": "object"},
    "timings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation", "serialization", "render", "layout", "total"],
      "properties": {
        "validation": {"type": "number", "minimum": 0},
        "serialization": {"type": "number", "minimum": 0},
        "render": {"type": "number", "minimum": 0},
        "layout": {"type": "number", "minimum": 0},
        "compare": {"type": "number", "minimum": 0},
        "total": {"type": "number", "minimum": 0}
      }
    },
    "approval": {
      "type": "object",
      "required": ["note", "ir_sha256"],
      "additionalProperties": false,
      "properties": {
        "note": {"type": "string"},
        "ir_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
