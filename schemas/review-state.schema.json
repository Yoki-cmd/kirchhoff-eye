{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kirchhoff-review-state-1.0.schema.json",
  "title": "kirchhoff-review-state/1.0",
  "type": "object",
  "required": [
    "report_version", "status", "task", "validation_status", "layout_status",
    "current_round", "max_rounds", "review_required", "ready_for_approval", "reason_codes",
    "rounds", "artifacts"
  ],
  "additionalProperties": true,
  "properties": {
    "report_version": {"const": "kirchhoff-review/1.0"},
    "status": {"enum": ["valid", "needs_review", "needs_human", "approved"]},
    "task": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {"kind": {"type": "string", "minLength": 1}}
    },
    "validation_status": {"enum": ["ok", "warn"]},
    "layout_status": {"enum": ["ok", "warn"]},
    "current_round": {"type": "integer", "minimum": 1},
    "max_rounds": {"type": "integer", "minimum": 1},
    "review_required": {"type": "boolean"},
    "ready_for_approval": {"type": "boolean"},
    "reason_codes": {"type": "array", "items": {"type": "string"}},
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["round", "reviewed", "regions", "differences", "applied_patches", "artifacts"],
        "additionalProperties": true,
        "properties": {
          "round": {"type": "integer", "minimum": 1},
          "reviewed": {"type": "boolean"},
          "regions": {"type": "array"},
          "differences": {"type": "array"},
          "applied_patches": {"type": "array"},
          "artifacts": {"type": "object"}
        }
      }
    },
    "artifacts": {"type": "object"}
  }
}
